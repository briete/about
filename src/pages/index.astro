---

<Layout title="About | Naoya Sato" currentPage="about">
  <main class="mx-auto max-w-xl px-6 pb-20 pt-28">
    <section id="about" class="mb-16">
      <h1 class="mb-6 text-3xl font-extrabold leading-tight tracking-tight">
        Naoya Sato
      </h1>
      <p
        class="mb-8 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400"
      >
        Software Engineer at Classmethod, Inc. <br /><br />
        Specializing in cloud-native web application development. Experienced in
        every phase from contract development to in-house product creation, including
        technology selection, design, implementation, and operations. Skilled at
        building robust and scalable cloud architectures.
      </p>
      <div class="flex flex-wrap items-center gap-4">
        {
          heroLinks.map(({ href, label, icon: Icon, iconSrc }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-1.5 rounded-full border border-neutral-200 px-3 py-1.5 text-xs font-bold transition-all hover:border-black hover:bg-black hover:text-white dark:border-neutral-700 dark:hover:border-white dark:hover:bg-white dark:hover:text-black"
            >
              {Icon ? (
                <Icon size={14} />
              ) : iconSrc ? (
                <img
                  src={typeof iconSrc === "string" ? iconSrc : iconSrc.src}
                  alt={label}
                  class="h-3.5 w-3.5"
                />
              ) : null}
              {label}
            </a>
          ))
        }
      </div>
    </section>

    <section class="mb-16">
      <div
        class="rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-700 dark:bg-neutral-800"
      >
        <div
          class="mb-6 flex items-center gap-2 text-neutral-900 dark:text-neutral-100"
        >
          <Award size={20} />
          <h2 class="text-lg font-bold">Certifications</h2>
        </div>

        <div class="space-y-8">
          <div>
            <h3
              class="mb-3 text-sm font-bold text-neutral-900 dark:text-neutral-100"
            >
              {certifications.ipa.title}
            </h3>
            <div class="flex flex-wrap gap-2">
              {
                certifications.ipa.certs.map(cert => (
                  <span class="rounded border border-neutral-200 bg-white px-2.5 py-1.5 text-[10px] font-medium text-neutral-600 dark:border-neutral-600 dark:bg-neutral-700 dark:text-neutral-300">
                    {cert}
                  </span>
                ))
              }
            </div>
          </div>

          <div>
            <div class="mb-3 flex items-center justify-between">
              <h3
                class="text-sm font-bold text-neutral-900 dark:text-neutral-100"
              >
                {certifications.aws.title}
              </h3>
            </div>

            <div class="mb-4 space-y-1">
              {
                certifications.aws.awards.map(award => (
                  <p class="text-xs text-neutral-500 dark:text-neutral-400">
                    <span class="font-bold text-neutral-700 dark:text-neutral-300">
                      {award.name}
                    </span>{" "}
                    ({award.period})
                  </p>
                ))
              }
            </div>
            <div class="flex flex-wrap gap-2">
              {
                certifications.aws.certs.map(cert => (
                  <span class="rounded border border-neutral-200 bg-white px-2.5 py-1.5 text-[10px] font-medium text-neutral-600 dark:border-neutral-600 dark:bg-neutral-700 dark:text-neutral-300">
                    AWS Certified {cert}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="skills" class="mb-16">
      <h2
        class="mb-6 text-xs font-bold uppercase tracking-widest text-neutral-400"
      >
        Skills
      </h2>
      <div class="space-y-4">
        <div
          class="rounded-xl border border-neutral-200 bg-white p-5 transition-colors hover:border-neutral-400 dark:border-neutral-700 dark:bg-neutral-800 dark:hover:border-neutral-500"
        >
          <div
            class="mb-4 flex items-center gap-2 border-b border-neutral-100 pb-2 dark:border-neutral-700"
          >
            <Cloud size={16} class="text-neutral-500 dark:text-neutral-400" />
            <h3 class="text-sm font-bold">Cloud & Infrastructure</h3>
          </div>
          <div class="space-y-3">
            {
              techStack.cloud.map(tech => (
                <div class="flex items-center justify-between text-xs">
                  <div class="flex items-center gap-3">
                    <img
                      src={tech.icon}
                      alt={tech.name}
                      class="h-5 w-5 object-contain"
                      loading="lazy"
                      width="20"
                      height="20"
                    />
                    <span class="font-mono font-medium text-neutral-700 dark:text-neutral-300">
                      {tech.name}
                    </span>
                  </div>
                  <span
                    class={`rounded border px-1.5 py-0.5 text-[10px] ${levelStyles[tech.level as Level]}`}
                  >
                    {tech.level}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="rounded-xl border border-neutral-200 bg-white p-5 transition-colors hover:border-neutral-400 dark:border-neutral-700 dark:bg-neutral-800 dark:hover:border-neutral-500"
        >
          <div
            class="mb-4 flex items-center gap-2 border-b border-neutral-100 pb-2 dark:border-neutral-700"
          >
            <Code size={16} class="text-neutral-500 dark:text-neutral-400" />
            <h3 class="text-sm font-bold">Languages & Frameworks</h3>
          </div>
          <div class="space-y-3">
            {
              techStack.languages.map(tech => (
                <div class="flex items-center justify-between text-xs">
                  <div class="flex items-center gap-3">
                    {tech.icon === "hono" ? (
                      <span class="flex h-5 w-5 items-center justify-center text-orange-500">
                        <Flame size={18} />
                      </span>
                    ) : (
                      <img
                        src={tech.icon}
                        alt={tech.name}
                        class="h-5 w-5 object-contain"
                        loading="lazy"
                        width="20"
                        height="20"
                      />
                    )}
                    <span class="font-mono font-medium text-neutral-700 dark:text-neutral-300">
                      {tech.name}
                    </span>
                  </div>
                  <span
                    class={`rounded border px-1.5 py-0.5 text-[10px] ${levelStyles[tech.level as Level]}`}
                  >
                    {tech.level}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section id="work" class="mb-20">
      <h2
        class="mb-8 text-xs font-bold uppercase tracking-widest text-neutral-400"
      >
        Work
      </h2>
      <div
        class="ml-2 space-y-12 border-l border-neutral-200 dark:border-neutral-700"
      >
        {
          workExperiences.map(exp => (
            <div class="relative pl-6">
              <span
                class={`absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full border border-white dark:border-neutral-900 ${exp.isCurrent ? "bg-black dark:bg-white" : "bg-neutral-300 dark:bg-neutral-600"}`}
              />
              {exp.period ? (
                <div class="mb-6">
                  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between">
                    <h3 class="text-base font-bold">{exp.company}</h3>
                    <span class="font-mono text-xs text-neutral-400">
                      {exp.period}
                    </span>
                  </div>
                </div>
              ) : (
                <h3 class="mb-4 text-sm font-bold text-neutral-900 dark:text-neutral-100">
                  {exp.company}
                </h3>
              )}
              <div class="grid gap-6">
                {exp.positions.map(pos => (
                  <div class="rounded-lg border border-neutral-200 bg-white p-5 transition-colors hover:border-neutral-400 dark:border-neutral-700 dark:bg-neutral-800 dark:hover:border-neutral-500">
                    <div class={`mb-2 flex items-start justify-between`}>
                      <h4 class="text-xs font-bold text-neutral-900 dark:text-neutral-100">
                        {pos.title}
                      </h4>
                      <span class="font-mono text-[10px] text-neutral-400">
                        {pos.period}
                      </span>
                    </div>
                    <p
                      class={`text-xs text-neutral-600 dark:text-neutral-400 ${pos.projects ? "mb-5 leading-relaxed" : "mb-2"}`}
                    >
                      {pos.description}
                    </p>
                    {pos.projects && (
                      <div class="space-y-5 text-neutral-600 dark:text-neutral-400">
                        {pos.projects.map(project => (
                          <div>
                            <h5 class="text-[11px] font-bold text-neutral-900 dark:text-neutral-100">
                              {project.title}
                            </h5>
                            <p class="mb-2 text-[10px] text-neutral-600 dark:text-neutral-400">
                              {project.description}
                            </p>
                            <div class="flex flex-wrap gap-1.5">
                              {project.techStack.map(tech => (
                                <span class="inline-flex items-center gap-1 rounded-full bg-neutral-100 py-0.5 pl-1 pr-2 font-mono text-[9px] font-medium text-neutral-600 dark:bg-neutral-700 dark:text-neutral-300">
                                  {techIcons[tech] === "hono" ? (
                                    <Flame size={10} class="text-orange-500" />
                                  ) : techIcons[tech] ? (
                                    <img
                                      src={techIcons[tech]}
                                      alt={tech}
                                      class="h-3 w-3"
                                    />
                                  ) : null}
                                  {tech}
                                </span>
                              ))}
                            </div>
                          </div>
                        ))}
                      </div>
                    )}
                    {pos.techStack && !pos.projects && (
                      <div class="flex flex-wrap gap-1.5 border-t border-neutral-100 pt-3 dark:border-neutral-700">
                        {pos.techStack.map(tech => (
                          <span class="inline-flex items-center gap-1 rounded-full bg-neutral-100 py-0.5 pl-1 pr-2 font-mono text-[9px] font-medium text-neutral-600 dark:bg-neutral-700 dark:text-neutral-300">
                            {techIcons[tech] === "hono" ? (
                              <Flame size={10} class="text-orange-500" />
                            ) : techIcons[tech] ? (
                              <img
                                src={techIcons[tech]}
                                alt={tech}
                                class="h-3 w-3"
                              />
                            ) : null}
                            {tech}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
