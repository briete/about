---
import { Moon, Sun, Terminal } from "@lucide/astro";

export interface Props {
  currentPage?: "about" | "blog";
}

const { currentPage } = Astro.props;
---

<nav
  class="fixed top-0 z-50 w-full border-b border-line/60 bg-paper/70 backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <a
      href="/"
      class="flex items-center gap-2 text-base font-bold tracking-tight text-ink hover:opacity-70"
    >
      <span class="rounded-md bg-brand p-1 text-white">
        <Terminal size={14} />
      </span>
      briete.me
    </a>
    <div class="flex items-center gap-4 text-xs font-medium text-muted">
      <a
        href="/"
        class={`transition-colors hover:text-ink ${currentPage === "about" ? "text-ink" : ""}`}
      >
        About
      </a>
      <a
        href="/blog"
        class={`transition-colors hover:text-ink ${currentPage === "blog" ? "text-ink" : ""}`}
      >
        Blog
      </a>
      <button
        type="button"
        id="theme-btn"
        class="rounded-md p-2 transition-colors hover:bg-line"
        aria-label="Toggle theme"
      >
        <Sun size={16} id="sun-svg" class="text-brand" />
        <Moon size={16} id="moon-svg" class="text-brand" />
      </button>
    </div>
  </div>
</nav>
